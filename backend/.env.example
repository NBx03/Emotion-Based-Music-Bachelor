DATABASE_URL=sqlite:///./app.db

# Провайдер генерации музыки: musicapi | sunoapi_box (см. backend/music_providers.py)
MUSIC_PROVIDER=musicapi

# musicapi.ai (https://docs.musicapi.ai/) - нужен только если MUSIC_PROVIDER=musicapi
MUSICAPI_TOKEN=your_musicapi_token_here
MUSICAPI_MODEL=sonic-v3-5

# api.box / Suno-реселлер (https://docs.api.box/) - нужен только если MUSIC_PROVIDER=sunoapi_box
SUNO_TOKEN=your_suno_token_here
